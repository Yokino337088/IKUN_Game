# ======================================
# Unity 官方标准 .gitignore
# 自动忽略无用文件，只提交项目核心资源
# ======================================

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/
MemoryCaptures/

# 打包输出
*.exe
*.dll
*.pdb
*.mdb
/[Bb]uilds/
/[Bb]uild/

# Visual Studio 缓存
.vs/
*.user
*.userprefs
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.proj
*.pidb
*.svd

# Rider / VS Code
.idea/
.vscode/
*.code-workspace

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 忽略本地配置
*.asset
*.backup

# ======================================
# 重要：以下文件 必须提交！不会被忽略
# ======================================
# Assets/
# ProjectSettings/
# Packages/
# *.meta
# ======================================